# Fat Finger — environment (copy to .env.local and fill at deploy).
# Everything runs without these set; features light up as keys are added.
# See ARCHITECTURE.md.

# ── Site ───────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://fatfinger.news"

# ── Email sending: Resend (renders our React newsletter as the email) ──
RESEND_API_KEY=""
EMAIL_FROM="Fat Finger <brief@fatfinger.news>"

# ── Subscribers DB: Supabase or Neon (Postgres) ────────
DATABASE_URL=""

# ── Live market data (top ticker) — flip on at launch ──
# CoinGecko needs no key (crypto). Add a stocks/commodities key when ready.
MARKET_DATA_API_KEY=""

# ── Skinny Finger Engine: the AI morning writer ────────
# Claude Opus 4.8 drafts each issue. Vercel sends CRON_SECRET as a Bearer token
# to /api/cron/write-issue so only the scheduler can trigger it.
ANTHROPIC_API_KEY=""
CRON_SECRET=""

# ── Payments: Stripe (premium quant/macro tier) ────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_ID_PREMIUM_MONTHLY=""
STRIPE_PRICE_ID_PREMIUM_ANNUAL=""
