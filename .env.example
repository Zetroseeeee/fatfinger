# Fat Finger — environment (copy to .env.local and fill at deploy).
# Everything runs without these set; features light up as keys are added.
# See ARCHITECTURE.md.

# ── Site ───────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://fatfinger.news"

# ── Email sending: Resend (renders our React newsletter as the email) ──
RESEND_API_KEY=""
EMAIL_FROM="Fat Finger <brief@fatfinger.news>"

# ── Subscribers DB: Supabase or Neon (Postgres) ────────
DATABASE_URL=""

# ── Live market data (top ticker) — flip on at launch ──
# CoinGecko needs no key (crypto). Add a stocks/commodities key when ready.
MARKET_DATA_API_KEY=""

# ── A/B testing + analytics + ad pixels ────────────────
# Optional. Locks the /ab results dashboard: when set, only /ab?key=THIS works.
# Leave unset pre-launch (the page is then public). Traffic is split 50/50 at
# the edge; the nightly /api/cron/optimize auto-promotes the winning variant.
AB_DASH_KEY=""
# Conversion pixels - set these only when you start running ads. Each is a no-op
# until set. The signup forms fire the matching conversion automatically.
NEXT_PUBLIC_META_PIXEL_ID=""
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_TIKTOK_PIXEL_ID=""

# ── Audio: "read it to me" narration ───────────────────
# ElevenLabs = the most human AI voice. Set the key and each issue gets a
# real-sounding narration (CDN-cached). Without it, the Listen button falls back
# to the browser's built-in voice. Pick any voice id from your ElevenLabs library.
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""

# ── Skinny Finger Engine: the AI morning writer ────────
# Claude Opus 4.8 drafts each issue. Vercel sends CRON_SECRET as a Bearer token
# to /api/cron/write-issue so only the scheduler can trigger it.
ANTHROPIC_API_KEY=""
CRON_SECRET=""

# ── Payments: Stripe (premium quant/macro tier) ────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_ID_PREMIUM_MONTHLY=""
STRIPE_PRICE_ID_PREMIUM_ANNUAL=""
